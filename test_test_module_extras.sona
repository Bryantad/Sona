print("=== test module extras ===");

import test;
import assert;

func runs() {
    assert.equal(1, 1);
};

func skipped() {
    assert.equal(1, 2);
};

test.describe("Only mode");
test.only("runs", runs);
test.it("skipped", skipped);

let summary = test.run_all();
print(summary);

test.snapshot({a: 1, b: 2}, "basic_snapshot");
