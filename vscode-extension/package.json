{
  "name": "sona-ai-native-programming",
  "displayName": "Sona: AI-Native Programming with Cognitive Accessibility",
  "description": "AI-native programming for real work and real minds, with Sona 0.15.1 Cognitive Diagnostics, CLI checks, local runtime integration, and the preview Sona AI Console.",
  "version": "0.15.1",
  "publisher": "Waycoreinc",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "AI",
    "Other"
  ],
  "keywords": [
    "sona",
    "ai",
    "programming",
    "cognitive",
    "cognitive-programming-language",
    "cognitive programming language",
    "accessibility",
    "adhd",
    "dyslexia",
    "neurotypical"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Bryantad/Sona.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sona",
        "aliases": [
          "Sona",
          "sona"
        ],
        "extensions": [
          ".sona",
          ".smod"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sona",
          "title": "Sona",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "sona": [
        {
          "id": "sona.aiConsole",
          "name": "Sona AI Console",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "sona.aiConsole.focus",
        "title": "Sona: Open AI Console",
        "category": "Sona",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "sona.aiConsole.clear",
        "title": "Sona: Clear AI Console",
        "category": "Sona",
        "icon": "$(clear-all)"
      },
      {
        "command": "sona.aiConsole.selectAgent",
        "title": "Sona: Select AI Agent",
        "category": "Sona",
        "icon": "$(account)"
      },
      {
        "command": "sona.welcome",
        "title": "Welcome & Setup",
        "category": "Sona",
        "icon": "$(home)"
      },
      {
        "command": "sona.aiPlanSelection",
        "title": "Sona: AI Plan Selection",
        "category": "Sona",
        "icon": "$(list-unordered)"
      },
      {
        "command": "sona.aiReviewSelection",
        "title": "Sona: AI Review Selection",
        "category": "Sona",
        "icon": "$(search)"
      },
      {
        "command": "sona.setup.azure",
        "title": "Setup Azure OpenAI",
        "category": "Sona",
        "icon": "$(cloud)"
      },
      {
        "command": "sona.setup.manual",
        "title": "Manual AI Setup",
        "category": "Sona",
        "icon": "$(gear)"
      },
      {
        "command": "sona.selectUserProfile",
        "title": "Select User Profile",
        "category": "Sona",
        "icon": "$(person)"
      },
      {
        "command": "sona.run",
        "title": "Run Sona File",
        "category": "Sona",
        "icon": "$(play)"
      },
      {
        "command": "sona.transpile",
        "title": "Transpile to Python",
        "category": "Sona",
        "icon": "$(arrow-right)"
      },
      {
        "command": "sona.repl",
        "title": "Start REPL",
        "category": "Sona",
        "icon": "$(terminal)"
      },
      {
        "command": "sona.check",
        "title": "Check Syntax",
        "category": "Sona",
        "icon": "$(check)"
      },
      {
        "command": "sona.format",
        "title": "Format Code",
        "category": "Sona",
        "icon": "$(word-wrap)"
      },
      {
        "command": "sona.explain",
        "title": "Explain Code",
        "category": "Sona",
        "icon": "$(question)"
      },
      {
        "command": "sona.suggest",
        "title": "Get AI Suggestions",
        "category": "Sona",
        "icon": "$(lightbulb)"
      },
      {
        "command": "sona.profile",
        "title": "Profile Performance",
        "category": "Sona",
        "icon": "$(graph)"
      },
      {
        "command": "sona.benchmark",
        "title": "Benchmark Code",
        "category": "Sona",
        "icon": "$(dashboard)"
      },
      {
        "command": "sona.info",
        "title": "Show System Info",
        "category": "Sona",
        "icon": "$(info)"
      },
      {
        "command": "sona.help",
        "title": "Help & Commands",
        "category": "Sona",
        "icon": "$(question)"
      },
      {
        "command": "sona.checkAIConnection",
        "title": "Check AI Connection",
        "category": "Sona",
        "icon": "$(pulse)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "sona.aiConsole.focus",
          "when": "true"
        },
        {
          "command": "sona.aiConsole.clear",
          "when": "true"
        },
        {
          "command": "sona.aiConsole.selectAgent",
          "when": "true"
        },
        {
          "command": "sona.welcome",
          "when": "true"
        },
        {
          "command": "sona.setup.azure",
          "when": "true"
        },
        {
          "command": "sona.setup.manual",
          "when": "true"
        },
        {
          "command": "sona.selectUserProfile",
          "when": "true"
        },
        {
          "command": "sona.run",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.transpile",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.repl",
          "when": "true"
        },
        {
          "command": "sona.check",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.format",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.explain",
          "when": "editorHasSelection"
        },
        {
          "command": "sona.suggest",
          "when": "editorLangId == sona || editorLangId == python || editorLangId == javascript"
        },
        {
          "command": "sona.profile",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.benchmark",
          "when": "editorLangId == sona"
        },
        {
          "command": "sona.info",
          "when": "true"
        },
        {
          "command": "sona.help",
          "when": "true"
        },
        {
          "command": "sona.checkAIConnection",
          "when": "true"
        }
      ],
      "view/title": [
        {
          "command": "sona.aiConsole.clear",
          "when": "view == sona.aiConsole",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "submenu": "sona.contextMenu",
          "when": "editorLangId == sona",
          "group": "sona"
        }
      ],
      "sona.contextMenu": [
        {
          "command": "sona.run",
          "when": "editorLangId == sona",
          "group": "execution"
        },
        {
          "command": "sona.transpile",
          "when": "editorLangId == sona",
          "group": "execution"
        },
        {
          "command": "sona.check",
          "when": "editorLangId == sona",
          "group": "validation"
        },
        {
          "command": "sona.format",
          "when": "editorLangId == sona",
          "group": "validation"
        },
        {
          "command": "sona.explain",
          "when": "editorHasSelection",
          "group": "ai"
        },
        {
          "command": "sona.suggest",
          "when": "editorLangId == sona",
          "group": "ai"
        }
      ]
    },
    "submenus": [
      {
        "id": "sona.contextMenu",
        "label": "Sona AI"
      }
    ],
    "configuration": {
      "title": "Sona",
      "properties": {
        "sona.cli.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python executable for running Sona CLI"
        },
        "sona.cli.timeout": {
          "type": "number",
          "default": 30000,
          "description": "CLI command timeout in milliseconds"
        },
        "sona.userProfile": {
          "type": "string",
          "enum": [
            "neurotypical",
            "adhd",
            "dyslexia"
          ],
          "default": "neurotypical",
          "description": "UI profile for accessibility optimization",
          "enumDescriptions": [
            "Standard UI/UX for typical users",
            "High-contrast, minimal distractions for ADHD",
            "Dyslexia-friendly fonts and enhanced readability"
          ]
        },
        "sona.ai.autoSetup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically prompt for AI setup when needed"
        },
        "sona.ai.defaultAgent": {
          "type": "string",
          "enum": [
            "sona",
            "qwen",
            "claude",
            "codex",
            "local"
          ],
          "default": "sona",
          "description": "Default agent selected in the Sona AI Console"
        },
        "sona.ai.qwen.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Qwen agent through a configured local Ollama endpoint"
        },
        "sona.ai.qwen.model": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Ollama model used by the Qwen agent"
        },
        "sona.ai.ollama.url": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Local Ollama endpoint for configured local providers"
        },
        "sona.ai.claude.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for a future Claude provider. Credentials are not stored in plaintext settings."
        },
        "sona.ai.codex.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for a future Codex provider. The extension does not control external Codex extensions."
        },
        "sona.onboarding.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message and profile setup on first use"
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:sona",
    "onView:sona.aiConsole",
    "onCommand:sona.aiConsole.focus",
    "onCommand:sona.aiConsole.clear",
    "onCommand:sona.aiConsole.selectAgent",
    "onCommand:sona.selectUserProfile",
    "onCommand:sona.welcome",
    "onStartupFinished"
  ],
  "scripts": {
    "verify:icon": "powershell -ExecutionPolicy Bypass -File scripts/verify-vsix-icon.ps1 -SkipVsix",
    "package:vsix": "npm run verify:icon && npx @vscode/vsce package && powershell -ExecutionPolicy Bypass -File scripts/verify-vsix-icon.ps1",
    "vscode:prepublish": "npm run verify:icon",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "node scripts/smoke-ai-console.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.60.0",
    "typescript": "^4.4.4"
  }
}
