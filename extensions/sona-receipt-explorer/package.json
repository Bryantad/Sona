{
    "name": "sona-receipt-explorer",
    "displayName": "Sona Receipt Explorer",
    "description": "Visualize, compare, and manage Sona receipts (execution, directory, and more) with a kind-aware tree view, detail panels, and diff tool",
    "version": "0.13.0",
    "publisher": "Waycoreinc",
    "license": "MIT",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/Bryantad/Sona"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other",
        "Visualization",
        "Debuggers"
    ],
    "keywords": [
        "sona",
        "receipt",
        "provenance",
        "execution",
        "reproducibility",
        "diff"
    ],
    "activationEvents": [
        "workspaceContains:**/*.receipt.json",
        "onView:sonaReceipts"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "sona-receipts",
                    "title": "Sona Receipts",
                    "icon": "$(file-binary)"
                }
            ]
        },
        "views": {
            "sona-receipts": [
                {
                    "id": "sonaReceipts",
                    "name": "Receipts",
                    "icon": "$(file-binary)",
                    "contextualTitle": "Sona Receipt Explorer"
                },
                {
                    "id": "sonaReceiptDetails",
                    "name": "Receipt Details",
                    "type": "webview",
                    "visibility": "collapsed"
                }
            ]
        },
        "commands": [
            {
                "command": "sonaReceipts.refresh",
                "title": "Refresh Receipts",
                "icon": "$(refresh)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.exploreReceipts",
                "title": "Explore Receipts",
                "icon": "$(file-binary)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.openReceipt",
                "title": "Open Receipt",
                "icon": "$(open-preview)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.compareReceipts",
                "title": "Compare Two Receipts",
                "icon": "$(diff)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.rerunFromReceipt",
                "title": "Re-run from Receipt",
                "icon": "$(debug-start)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.copyReproduceCommand",
                "title": "Copy Reproduce Command",
                "icon": "$(clippy)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.openReceiptJson",
                "title": "Open Raw Receipt JSON",
                "icon": "$(json)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.verifyReceiptChain",
                "title": "Verify Receipt Chain",
                "icon": "$(link)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.exportReceiptBundle",
                "title": "Export Receipt Bundle",
                "icon": "$(package)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.verifySignature",
                "title": "Verify Receipt Signature",
                "icon": "$(shield-check)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.redactReceipt",
                "title": "Redact Receipt",
                "icon": "$(eye-closed)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.deleteReceipt",
                "title": "Delete Receipt",
                "icon": "$(trash)",
                "category": "Sona Receipts"
            },
            {
                "command": "sonaReceipts.exportReceipt",
                "title": "Export Receipt as Markdown",
                "icon": "$(markdown)",
                "category": "Sona Receipts"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "sonaReceipts.refresh",
                    "when": "view == sonaReceipts",
                    "group": "navigation"
                },
                {
                    "command": "sonaReceipts.exploreReceipts",
                    "when": "view == sonaReceipts",
                    "group": "navigation"
                },
                {
                    "command": "sonaReceipts.compareReceipts",
                    "when": "view == sonaReceipts",
                    "group": "navigation"
                },
                {
                    "command": "sonaReceipts.verifyReceiptChain",
                    "when": "view == sonaReceipts",
                    "group": "navigation"
                },
                {
                    "command": "sonaReceipts.exportReceiptBundle",
                    "when": "view == sonaReceipts",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "sonaReceipts.openReceipt",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "inline"
                },
                {
                    "command": "sonaReceipts.rerunFromReceipt",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "1_actions"
                },
                {
                    "command": "sonaReceipts.copyReproduceCommand",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "1_actions"
                },
                {
                    "command": "sonaReceipts.openReceiptJson",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.exportReceipt",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.verifyReceiptChain",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.exportReceiptBundle",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.verifySignature",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.redactReceipt",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "2_export"
                },
                {
                    "command": "sonaReceipts.deleteReceipt",
                    "when": "view == sonaReceipts && viewItem == receipt",
                    "group": "3_danger"
                }
            ]
        },
        "configuration": {
            "title": "Sona Receipt Explorer",
            "properties": {
                "sonaReceipts.autoRefresh": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically refresh when receipt files change"
                },
                "sonaReceipts.showTimestamps": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show timestamps in the tree view"
                },
                "sonaReceipts.groupByDate": {
                    "type": "boolean",
                    "default": true,
                    "description": "Group receipts by date"
                },
                "sonaReceipts.maxReceipts": {
                    "type": "number",
                    "default": 100,
                    "description": "Maximum number of receipts to display"
                },
                "sonaReceipts.receiptGlob": {
                    "type": "string",
                    "default": "**/*.receipt.json",
                    "description": "Glob pattern used to discover receipt files"
                },
                "sonaReceipts.statusFilter": {
                    "type": "string",
                    "enum": [
                        "all",
                        "success",
                        "failed"
                    ],
                    "default": "all",
                    "description": "Filter visible receipts by execution status"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package:vsix": "python scripts/build_deterministic_vsix.py",
        "package:vsix:verify": "python scripts/build_deterministic_vsix.py --verify"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "18.x",
        "typescript": "^5.0.0"
    }
}