const module_format = "smod-runtime"
const runtime_backend = "smod"

func configure(options) { return experimental_configure(options) }
func status() { return experimental_status() }
func card(task, last_step=nil, next_step=nil) {
    if last_step == nil { last_step = "" }
    if next_step == nil { next_step = "" }
    return reentry_card(task, last_step, next_step)
}
func prompt(task) { return reentry_prompt(task) }
