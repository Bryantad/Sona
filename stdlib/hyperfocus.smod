const module_format = "smod-runtime"
const runtime_backend = "smod"

func configure(options) { return experimental_configure(options) }
func status() { return experimental_status() }
func check(minutes, break_interval=nil) {
    if break_interval == nil { break_interval = 50 }
    return hyperfocus_check(minutes, break_interval)
}
func plan(task, minutes=nil) {
    if minutes == nil { minutes = 50 }
    return hyperfocus_plan(task, minutes)
}
